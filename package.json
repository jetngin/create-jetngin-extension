{
  "name": "create-jetngin-extension",
  "version": "0.0.0",
  "description": "starter extension for jetngin",
  "bin": "dist/generate.js",
  "types": "dist/generate.d.ts",
  "prepublish": "tsc",
  "scripts": {
    "uat": "npm run build && node dist/generate myapp",
    "pr": "npm run build && npm run lint",
    "clean": "tsc --build --clean",
    "build": "tsc --build",
    "watch": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "fix": "eslint --fix --ext .ts .",
    "eslint": "eslint",
    "audit": "npx audit-ci --moderate",
    "test": "npm run pr"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jetngin/create-jetngin-extension.git"
  },
  "keywords": [
    "starter",
    "node",
    "jet",
    "package"
  ],
  "author": "Daniel Samson <contact@nodejet.org>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jetngin/create-jetngin-extension/issues"
  },
  "homepage": "https://nodejet.org",
  "dependencies": {
    "extract-zip": "2.0.1",
    "request": "2.88.2"
  },
  "devDependencies": {
    "@types/chai": "4.3.1",
    "@types/mocha": "9.1.1",
    "@types/mock-fs": "4.13.1",
    "@types/node": "16.11.41",
    "@types/sinon": "10.0.11",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "audit-ci": "6.3.0",
    "chai": "4.3.6",
    "eslint": "8.18.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-import-resolver-typescript": "2.7.1",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-jsdoc": "39.3.3",
    "eslint-plugin-mocha": "10.0.5",
    "eslint-plugin-sonarjs": "0.13.0",
    "install": "0.13.0",
    "nyc": "15.1.0",
    "sinon": "14.0.0",
    "source-map-support": "0.5.21",
    "ts-node": "10.8.1",
    "typescript": "4.7.4"
  }
}